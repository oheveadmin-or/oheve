{
  "expo": {
    "name": "Oheve",
    "slug": "oheve",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "monapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.oheve.wedding",
      "usesAppleSignIn": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryUsageDescription": "Oheve accède à vos photos pour vous permettre d'ajouter une photo de profil, des photos à votre portfolio et à votre site de mariage.",
        "NSCameraUsageDescription": "Oheve utilise l'appareil photo pour vous permettre de prendre une photo de profil ou des photos pour votre site de mariage.",
        "CFBundleAllowMixedLocalizations": true,
        "CFBundleDevelopmentRegion": "fr"
      }
    },
    "android": {
      "package": "com.oheve.wedding",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-apple-authentication",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-font",
      "expo-image",
      "expo-sharing",
      "expo-status-bar",
      "expo-web-browser",
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.oheve.app"
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.328961509377-jh9p68eq9o11d3700atgga34u9vartlq"
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          }
        }
      ],
      "expo-video"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "owner": "odou2000s-team",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "aebc2135-3ca1-4b4b-8a2c-d58fceeadc1a"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/aebc2135-3ca1-4b4b-8a2c-d58fceeadc1a"
    }
  }
}
