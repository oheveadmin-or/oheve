# Build production uniquement : origine de l’API (sans /api). En `npm run dev`, les requêtes passent par le proxy Vite (/api).
# VITE_API_BASE_URL=https://ton-api.example.com
VITE_API_BASE_URL=

# Dev : cible du proxy → backend HTTP sur la machine (port réel du backend).
# VITE_DEV_PROXY_API=http://127.0.0.1:3003
